<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:VinhKhanhstreetfoods.Converters;assembly=VinhKhanhstreetfoods"
             xmlns:viewmodels="clr-namespace:VinhKhanhstreetfoods.ViewModels"
             xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
             x:Class="VinhKhanhstreetfoods.Views.MapPage"
             Title="Map"
             BackgroundColor="#F5F6F8"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter" />
            <converters:StringNotNullOrEmptyConverter x:Key="StringNotNullOrEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView x:Name="MainScrollView">
        <StackLayout x:Name="MainStackLayout" Spacing="15" Padding="15">

            <!-- Header -->
            <Frame x:Name="HeaderFrame" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="False">
                <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                    <Image Source="map_icon.png" WidthRequest="30" HeightRequest="30" VerticalOptions="Center" Grid.Column="0" Margin="0,0,10,0" />

                    <StackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label x:Name="HeaderTitleLabel" FontSize="20" FontAttributes="Bold" TextColor="#1F2937" />
                        <Label x:Name="HeaderSubtitleLabel" FontSize="12" TextColor="#6B7280" />
                    </StackLayout>

                    <Frame Grid.Column="2" BackgroundColor="#F4A950" CornerRadius="20" Padding="10" HasShadow="False" WidthRequest="40" HeightRequest="40" VerticalOptions="Center" HorizontalOptions="Center">
                        <Image Source="home.png" WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                </Grid>
            </Frame>

            <!-- Location Card -->
            <Frame x:Name="LocationCardFrame" BackgroundColor="#E5F3FF" CornerRadius="12" Padding="10" HasShadow="False">
                <Frame BackgroundColor="White" CornerRadius="12" Padding="10" HasShadow="False">
                    <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                        <Frame Grid.Column="0" BackgroundColor="#F4A950" CornerRadius="20" Padding="8" HasShadow="False" WidthRequest="40" HeightRequest="40" VerticalOptions="Center" HorizontalOptions="Center" Margin="0,0,10,0">
                            <Image Source="map_pin_alt_svgrepo_com.png" WidthRequest="16" HeightRequest="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <StackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label x:Name="CurrentLocationTitleLabel" FontSize="16" FontAttributes="Bold" TextColor="#1F2937" />
                            <Label x:Name="CurrentLocationSubtitleLabel" FontSize="12" TextColor="#6B7280" />
                        </StackLayout>
                        <Frame Grid.Column="2" BackgroundColor="#F3F4F6" CornerRadius="15" Padding="5" HasShadow="False" WidthRequest="30" HeightRequest="30" VerticalOptions="Center" HorizontalOptions="Center">
                            <Image Source="refresh_svgrepo_com.png" WidthRequest="14" HeightRequest="14" HorizontalOptions="Center" VerticalOptions="Center">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                                </Image.GestureRecognizers>
                            </Image>
                        </Frame>
                    </Grid>
                </Frame>
            </Frame>

            <!-- Map View -->
            <Grid>
                <Frame x:Name="MapFrame" BackgroundColor="White"
                       BorderColor="#E5E7EB"
                       CornerRadius="15"
                       Padding="0"
                       HasShadow="False">
                    <WebView x:Name="MapWebView" HeightRequest="350">
                        <WebView.Source>
                            <HtmlWebViewSource>
                                <HtmlWebViewSource.Html>
                                    <![CDATA[
                                <!DOCTYPE html>
                                <html>
                                <head>
                                <meta charset="utf-8" />
                                <title>TrackAsia Map</title>
                                <link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
                                <style>
                                body { margin:0; padding:0; }
                                #map { width:100%; height:100vh; }
                                .poi-marker {
                                    width: 32px;
                                    height: 32px;
                                    border-radius: 50%;
                                    background: #0A84FF;
                                    border: 2px solid white;
                                    box-shadow: 0 2px 6px rgba(0,0,0,0.25);
                                    background-size: cover;
                                    background-position: center;
                                    cursor: pointer;
                                }
                                .poi-popup {
                                    font-family: sans-serif;
                                    max-width: 220px;
                                }
                                .poi-popup .poi-title {
                                    font-weight: 700;
                                    color: #111827;
                                    margin-bottom: 4px;
                                }
                                .poi-popup .poi-sub {
                                    font-size: 12px;
                                    color: #6B7280;
                                    margin-bottom: 6px;
                                }
                                .poi-popup .poi-desc {
                                    font-size: 12px;
                                    color: #374151;
                                    margin-bottom: 8px;
                                }
                                .poi-popup button {
                                    background: #0A84FF;
                                    color: #fff;
                                    border: none;
                                    border-radius: 8px;
                                    padding: 8px 10px;
                                    font-size: 12px;
                                    cursor: pointer;
                                }
                                .poi-popup button:active { opacity: 0.9; }
                                </style>
                                </head>
                                <body>
                                <div id="map"></div>
                                <script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
                                <script>
                                mapboxgl.accessToken = "bca01773651908dcc9bc6320f7c16973ce";
                                const map = new mapboxgl.Map({
                                    container: 'map',
                                    style: 'https://maps.track-asia.com/styles/v1/streets.json?key=bca01773651908dcc9bc6320f7c16973ce',
                                    center: [106.700981,10.776530],
                                    zoom: 15
                                });

                                let userMarker = null;
                                let isLocationEnabled = false;
                                const poiMarkers = new Map();
                                let hasFirstFix = false;
                                let detailButtonText = 'View details';

                                function setDetailButtonText(text) {
                                    detailButtonText = text || 'View details';
                                }

                                function focusPOI(id) {
                                    const marker = poiMarkers.get(id);
                                    if (!marker) return;
                                    const ll = marker.getLngLat();
                                    map.flyTo({ center: ll, zoom: 17, speed: 1.5 });
                                    const popup = marker.getPopup?.();
                                    if (popup) popup.addTo(map);
                                }

                                function setTrackingState(isActive) {
                                    isLocationEnabled = isActive;
                                }

                                function updateLocation(lat, lng) {
                                    if (!userMarker) {
                                        userMarker = new mapboxgl.Marker({ color: '#FF0000' })
                                            .setLngLat([lng, lat])
                                            .addTo(map);
                                        map.flyTo({ center: [lng, lat], speed: 1.5, zoom: 16 });
                                        hasFirstFix = true;
                                    } else {
                                        userMarker.setLngLat([lng, lat]);
                                        if (!hasFirstFix) {
                                            map.flyTo({ center: [lng, lat], speed: 1.5, zoom: 16 });
                                            hasFirstFix = true;
                                        }
                                    }
                                }

                                function recenterMap() {
                                    if (userMarker) {
                                        map.flyTo({ center: userMarker.getLngLat(), speed: 1.5, zoom: 16 });
                                        hasFirstFix = true;
                                    }
                                }

                                function openPoiDetail(id) {
                                    window.location.href = `app://poi?id=${id}`;
                                }

                                function createPoiElement(p) {
                                    const el = document.createElement('div');
                                    el.className = 'poi-marker';
                                    if (p.imageUrl) {
                                        el.style.backgroundImage = `url(${p.imageUrl})`;
                                    }
                                    return el;
                                }

                                function renderPOIs(pois) {
                                    poiMarkers.forEach(m => m.remove());
                                    poiMarkers.clear();

                                    if (!pois || pois.length === 0) return;

                                    const bounds = new mapboxgl.LngLatBounds();
                                    pois.forEach(p => {
                                        const el = createPoiElement(p);

                                        const popupHtml = `
<div class="poi-popup">
  <div class="poi-title">${p.name ?? ''}</div>
  <div class="poi-sub">${p.address ?? ''}</div>
  <div class="poi-desc">${(p.desc ?? '').slice(0, 90)}${(p.desc && p.desc.length > 90) ? '...' : ''}</div>
  <button onclick="openPoiDetail(${p.id})">${detailButtonText}</button>
</div>`;

                                        const marker = new mapboxgl.Marker({ element: el })
                                            .setLngLat([p.lng, p.lat])
                                            .setPopup(new mapboxgl.Popup({ offset: 25 }).setHTML(popupHtml))
                                            .addTo(map);

                                        poiMarkers.set(p.id, marker);
                                        bounds.extend([p.lng, p.lat]);
                                    });

                                    if (!bounds.isEmpty()) {
                                        map.fitBounds(bounds, { padding: 40, maxZoom: 17 });
                                    }
                                }

                                class CustomGeolocateControl {
                                    onAdd(map) {
                                        this.map = map;
                                        this.container = document.createElement('div');
                                        this.container.className = 'mapboxgl-ctrl mapboxgl-ctrl-group';

                                        const btn = document.createElement('button');
                                        btn.className = 'mapboxgl-ctrl-icon mapboxgl-ctrl-geolocate';
                                        btn.id = 'auto-geolocate-btn';
                                        btn.type = 'button';
                                        btn.title = 'My location';
                                        btn.onclick = () => recenterMap();

                                        this.container.appendChild(btn);
                                        return this.container;
                                    }
                                    onRemove() {
                                        this.container.parentNode.removeChild(this.container);
                                        this.map = undefined;
                                    }
                                }

                                map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');
                                map.addControl(new CustomGeolocateControl(), 'bottom-right');
                                </script>
                                </body>
                                </html>
                                ]]>
                                </HtmlWebViewSource.Html>
                            </HtmlWebViewSource>
                        </WebView.Source>
                    </WebView>
                </Frame>

                <Button x:Name="ToggleFullScreenBtn"
                        Text="⛶"
                        FontSize="20"
                        BackgroundColor="#AA000000"
                        TextColor="White"
                        CornerRadius="20"
                        WidthRequest="40"
                        HeightRequest="40"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        Margin="10"
                        Padding="0"
                        Clicked="OnToggleFullScreenClicked" />
            </Grid>

            <!-- Nearby Restaurants Header -->
            <Grid x:Name="NearbyHeaderGrid" ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center" Margin="0,10,0,0">
                <Label x:Name="NearbyHeaderTitleLabel" FontSize="18" FontAttributes="Bold" TextColor="#1F2937" Grid.Column="0" />
                <Label Text="{Binding AllPOIs.Count, StringFormat='{0} địa điểm'}" FontSize="12" TextColor="#F4A950" Grid.Column="2" VerticalOptions="Center" />
            </Grid>

            <!-- Horizontal Collection of POIs -->
            <CollectionView x:Name="POIsCollectionView" ItemsSource="{Binding AllPOIs}" ItemsLayout="HorizontalList" HeightRequest="260">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" CornerRadius="15" Padding="0" HasShadow="True" Margin="0,0,15,5" WidthRequest="220">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MapViewModel}}, Path=OpenDetailCommand}" CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <StackLayout>
                                <Grid HeightRequest="120">
                                    <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="0" IsVisible="{Binding BannerImageUrl, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="15,15,0,0" />
                                        </Border.StrokeShape>
                                        <Image Source="{Binding BannerImageUrl}" Aspect="AspectFill" />
                                    </Border>
                                    <BoxView BackgroundColor="#111827" CornerRadius="15,15,0,0" IsVisible="{Binding BannerImageUrl, Converter={StaticResource IsNullOrEmptyConverter}}" />
                                    <Frame BackgroundColor="#10B981" CornerRadius="10" Padding="8,4" HorizontalOptions="End" VerticalOptions="Start" Margin="10" HasShadow="False">
                                        <Label Text="1.2 km" TextColor="White" FontSize="10" FontAttributes="Bold" />
                                    </Frame>
                                </Grid>

                                <StackLayout Padding="12" Spacing="8">
                                    <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" TextColor="#1F2937" LineBreakMode="TailTruncation" />

                                    <StackLayout Orientation="Horizontal" Spacing="5">
                                        <Image Source="map_pin_alt_svgrepo_com.png" WidthRequest="12" HeightRequest="12" />
                                        <Label Text="Phố Vĩnh Khánh, Quận 4, TP.HCM" FontSize="10" TextColor="#6B7280" LineBreakMode="TailTruncation" />
                                    </StackLayout>

                                    <StackLayout Orientation="Horizontal" Spacing="5">
                                        <Label Text="💬" FontSize="12" TextColor="#F4A950" />
                                        <Label Text="Tiếng Việt" FontSize="10" TextColor="#F4A950" />
                                    </StackLayout>

                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,5,0,0">
                                        <Frame Grid.Column="0" BackgroundColor="#AF45DB" CornerRadius="20" Padding="0" HasShadow="False" HeightRequest="30">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MapViewModel}}, Path=PlayAudioCommand}" CommandParameter="{Binding .}" />
                                            </Frame.GestureRecognizers>
                                            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                                                <Image Source="sound_volume_2_svgrepo_com.png" WidthRequest="12" HeightRequest="12" VerticalOptions="Center"/>
                                                <Label Text="Nghe hướng dẫn" TextColor="White" FontSize="10" VerticalOptions="Center" FontAttributes="Bold" />
                                            </StackLayout>
                                        </Frame>
                                        <Frame Grid.Column="1" BackgroundColor="Transparent" BorderColor="#D1D5DB" CornerRadius="20" Padding="0" HasShadow="False" HeightRequest="30">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MapViewModel}}, Path=OpenDetailCommand}" CommandParameter="{Binding .}" />
                                            </Frame.GestureRecognizers>
                                            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                                                <Image Source="information_alt_svgrepo_com.png" WidthRequest="12" HeightRequest="12" VerticalOptions="Center"/>
                                                <Label Text="Xem chi tiết" TextColor="#6B7280" FontSize="10" VerticalOptions="Center" />
                                            </StackLayout>
                                        </Frame>
                                    </Grid>
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Stats -->
            <Label x:Name="StatsHeaderLabel" FontSize="18" FontAttributes="Bold" TextColor="#1F2937" Margin="0,10,0,0" />

            <Grid x:Name="StatsGrid" ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,0,0,20">
                <Frame Grid.Column="0" BackgroundColor="#E6F4FC" CornerRadius="12" Padding="15" HasShadow="False">
                    <StackLayout Spacing="10">
                        <StackLayout Orientation="Horizontal" Spacing="5">
                            <Image Source="user_svgrepo_com.png" WidthRequest="14" HeightRequest="14" />
                            <Label x:Name="StatsExploredLabel" FontSize="12" TextColor="#4B5563" />
                        </StackLayout>
                        <Label Text="1" FontSize="32" FontAttributes="Bold" TextColor="#F4A950" />
                    </StackLayout>
                </Frame>

                <Frame Grid.Column="1" BackgroundColor="#FDF2F8" CornerRadius="12" Padding="15" HasShadow="False">
                    <StackLayout Spacing="10">
                        <StackLayout Orientation="Horizontal" Spacing="5">
                            <Image Source="sound_volume_2_svgrepo_com.png" WidthRequest="14" HeightRequest="14" />
                            <Label x:Name="StatsListenedLabel" FontSize="12" TextColor="#4B5563" />
                        </StackLayout>
                        <Label Text="1" FontSize="32" FontAttributes="Bold" TextColor="#AF45DB" />
                    </StackLayout>
                </Frame>
            </Grid>

        </StackLayout>
        </ScrollView>
        <components:NowPlayingBar Margin="0,0,0,20" />
    </Grid>
</ContentPage>
