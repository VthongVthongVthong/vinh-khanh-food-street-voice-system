<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhstreetfoods.Views.MapPage"
             Title="Bản Đồ Vĩnh Khánh"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="15">
        
        <!-- Header -->
        <Label Grid.Row="0" 
               Text="📍 Bản Đồ Địa Điểm Ẩm Thực" 
               FontSize="24" 
               FontAttributes="Bold"
               TextColor="#283845"
               HorizontalOptions="Center"/>

        <!-- Map Simulation and POI List -->
        <ScrollView Grid.Row="1">
            <StackLayout Spacing="15">
                
                <!-- Map Placeholder -->
                <Frame BackgroundColor="White"
                       BorderColor="#C9A36B"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">
                    <StackLayout Spacing="10" HeightRequest="250">
                        <Label Text="Google Maps Integration" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#283845"
                               HorizontalOptions="Center"/>
                        <Label Text="(Google Maps API implementation)" 
                               FontSize="12" 
                               TextColor="Gray"
                               HorizontalOptions="Center"/>
                        <BoxView BackgroundColor="#E8E8E8" />
                    </StackLayout>
                </Frame>

                <!-- POI List -->
                <Frame BackgroundColor="White"
                       BorderColor="#C9A36B"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">
                    <StackLayout Spacing="10">
                        <Label Text="Danh Sách Địa Điểm" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#283845"/>
                        <CollectionView ItemsSource="{Binding AllPOIs}"
                                       SelectionMode="Single"
                                       SelectedItem="{Binding SelectedPOI}"
                                       SelectionChangedCommand="{Binding OpenMapCommand}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <StackLayout Padding="10" Spacing="5">
                                        <Label Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontAttributes="Bold"
                                               TextColor="#C9A36B"/>
                                        <Label Text="{Binding DescriptionText}" 
                                               FontSize="11" 
                                               TextColor="#666666"
                                               LineBreakMode="TailTruncation"/>
                                    </StackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                </Frame>

                <!-- Status -->
                <Frame BackgroundColor="#283845"
                       CornerRadius="10"
                       Padding="10">
                    <Label Text="{Binding StatusMessage}" 
                           TextColor="White" 
                           FontSize="12"
                           HorizontalOptions="Center"/>
                </Frame>
            </StackLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <Button Grid.Row="2" 
                Text="🔄 Làm Mới" 
                Command="{Binding RefreshCommand}"
                BackgroundColor="#C9A36B"
                TextColor="Black"
                FontSize="14"
                FontAttributes="Bold"
                CornerRadius="10"
                Padding="15"/>
    </Grid>
</ContentPage>
