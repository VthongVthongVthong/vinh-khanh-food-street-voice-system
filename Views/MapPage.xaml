<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhstreetfoods.Views.MapPage"
             Title="Bản Đồ"
             BackgroundColor="#F5F6F8"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <StackLayout Spacing="15" Padding="15">
            
            <!-- Header -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="False">
                <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                    <Image Source="map_icon.png" WidthRequest="30" HeightRequest="30" VerticalOptions="Center" Grid.Column="0" Margin="0,0,10,0" />
                    <!-- Using text symbols if images don't exist -->
                    <Label Text="🗺" FontSize="30" VerticalOptions="Center" Grid.Column="0" Margin="0,0,10,0"/>

                    <StackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Bản Đồ Ẩm Thực" FontSize="20" FontAttributes="Bold" TextColor="#1F2937" />
                        <Label Text="Khám phá nhà hàng trên phố Vĩnh Khánh" FontSize="12" TextColor="#6B7280" />
                    </StackLayout>

                    <Frame Grid.Column="2" BackgroundColor="#0079D3" CornerRadius="20" Padding="10" HasShadow="False" WidthRequest="40" HeightRequest="40" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="🏠" TextColor="White" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                </Grid>
            </Frame>

            <!-- Location Card -->
            <Frame BackgroundColor="#E5F3FF" CornerRadius="12" Padding="10" HasShadow="False">
                <Frame BackgroundColor="White" CornerRadius="12" Padding="10" HasShadow="False">
                    <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                        <Frame Grid.Column="0" BackgroundColor="#0079D3" CornerRadius="20" Padding="8" HasShadow="False" WidthRequest="40" HeightRequest="40" VerticalOptions="Center" HorizontalOptions="Center" Margin="0,0,10,0">
                            <Label Text="📍" TextColor="White" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <StackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Vị trí của bạn" FontSize="16" FontAttributes="Bold" TextColor="#1F2937" />
                            <Label Text="Phố Vĩnh Khánh, Quận 4, TP.HCM" FontSize="12" TextColor="#6B7280" />
                        </StackLayout>
                        <Frame Grid.Column="2" BackgroundColor="#F3F4F6" CornerRadius="15" Padding="5" HasShadow="False" WidthRequest="30" HeightRequest="30" VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="🔄" TextColor="#0079D3" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Frame>
                    </Grid>
                </Frame>
            </Frame>

            <!-- Map View -->
            <Frame BackgroundColor="White"
                   BorderColor="#E5E7EB"
                   CornerRadius="15"
                   Padding="0"
                   HasShadow="False">
                <WebView HeightRequest="350">
                    <WebView.Source>
                        <HtmlWebViewSource>
                            <HtmlWebViewSource.Html>
                                <![CDATA[
                                <!DOCTYPE html>
                                <html>
                                <head>
                                <meta charset="utf-8" />
                                <title>TrackAsia Map</title>
                                <link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
                                <style>
                                body { margin:0; padding:0; }
                                #map { width:100%; height:100vh; }
                                </style>
                                </head>
                                <body>
                                <div id="map"></div>
                                <script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
                                <script>
                                mapboxgl.accessToken = "bca01773651908dcc9bc6320f7c16973ce";
                                const map = new mapboxgl.Map({
                                    container: 'map',
                                    style: 'https://maps.track-asia.com/styles/v1/streets.json?key=bca01773651908dcc9bc6320f7c16973ce',
                                    center: [106.700981,10.776530],
                                    zoom: 15
                                });
                                new mapboxgl.Marker({ color: '#0079D3' })
                                    .setLngLat([106.700981,10.776530])
                                    .addTo(map);
                                // Control
                                map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');
                                </script>
                                </body>
                                </html>
                                ]]>
                            </HtmlWebViewSource.Html>
                        </HtmlWebViewSource>
                    </WebView.Source>
                </WebView>
            </Frame>

            <!-- Nearby Restaurants Header -->
            <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center" Margin="0,10,0,0">
                <Label Text="🏪 Nhà hàng gần bạn" FontSize="18" FontAttributes="Bold" TextColor="#1F2937" Grid.Column="0" />
                <Label Text="{Binding AllPOIs.Count, StringFormat='{0} địa điểm'}" FontSize="12" TextColor="#0079D3" Grid.Column="2" VerticalOptions="Center" />
            </Grid>

            <!-- Horizontal Collection of POIs -->
            <CollectionView ItemsSource="{Binding AllPOIs}" ItemsLayout="HorizontalList" HeightRequest="260">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" CornerRadius="15" Padding="0" HasShadow="True" Margin="0,0,15,5" WidthRequest="220">
                            <StackLayout>
                                <!-- Map/Image placeholder -> We will just use a black box for now per reference design -->
                                <Grid HeightRequest="120">
                                    <BoxView BackgroundColor="#111827" CornerRadius="15,15,0,0" />
                                    <!-- Distance Badge -->
                                    <Frame BackgroundColor="#10B981" CornerRadius="10" Padding="8,4" HorizontalOptions="End" VerticalOptions="Start" Margin="10" HasShadow="False">
                                        <Label Text="1.2 km" TextColor="White" FontSize="10" FontAttributes="Bold" />
                                    </Frame>
                                </Grid>
                                
                                <StackLayout Padding="12" Spacing="8">
                                    <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" TextColor="#1F2937" LineBreakMode="TailTruncation" />
                                    
                                    <StackLayout Orientation="Horizontal" Spacing="5">
                                        <Label Text="📍" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="Phố Vĩnh Khánh, Quận 4, TP.HCM" FontSize="10" TextColor="#6B7280" LineBreakMode="TailTruncation" />
                                    </StackLayout>
                                    
                                    <StackLayout Orientation="Horizontal" Spacing="5">
                                        <Label Text="💬" FontSize="12" TextColor="#0079D3" />
                                        <Label Text="Tiếng Việt" FontSize="10" TextColor="#0079D3" />
                                    </StackLayout>
                                    
                                    <!-- Buttons -->
                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,5,0,0">
                                        <Frame Grid.Column="0" BackgroundColor="#AF45DB" CornerRadius="20" Padding="0" HasShadow="False" HeightRequest="30">
                                            <Label Text="🔊 Nghe hướng dẫn" TextColor="White" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" />
                                        </Frame>
                                        <Frame Grid.Column="1" BackgroundColor="Transparent" BorderColor="#D1D5DB" CornerRadius="20" Padding="0" HasShadow="False" HeightRequest="30">
                                            <Label Text="ℹ️ Xem chi tiết" TextColor="#6B7280" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Frame>
                                    </Grid>
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Stats -->
            <Label Text="Thống kê khám phá" FontSize="18" FontAttributes="Bold" TextColor="#1F2937" Margin="0,10,0,0" />
            
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,0,0,20">
                <!-- Explored Card -->
                <Frame Grid.Column="0" BackgroundColor="#E6F4FC" CornerRadius="12" Padding="15" HasShadow="False">
                    <StackLayout Spacing="10">
                        <StackLayout Orientation="Horizontal" Spacing="5">
                            <Label Text="🪪" FontSize="14" TextColor="#0079D3" />
                            <Label Text="Đã khám phá" FontSize="12" TextColor="#4B5563" />
                        </StackLayout>
                        <Label Text="1" FontSize="32" FontAttributes="Bold" TextColor="#0079D3" />
                    </StackLayout>
                </Frame>
                
                <!-- Guides Listened Card -->
                <Frame Grid.Column="1" BackgroundColor="#FDF2F8" CornerRadius="12" Padding="15" HasShadow="False">
                    <StackLayout Spacing="10">
                        <StackLayout Orientation="Horizontal" Spacing="5">
                            <Label Text="🔊" FontSize="14" TextColor="#AF45DB" />
                            <Label Text="Hướng dẫn đã nghe" FontSize="12" TextColor="#4B5563" />
                        </StackLayout>
                        <Label Text="1" FontSize="32" FontAttributes="Bold" TextColor="#AF45DB" />
                    </StackLayout>
                </Frame>
            </Grid>

        </StackLayout>
    </ScrollView>
</ContentPage>
