<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:VinhKhanhstreetfoods.Converters;assembly=VinhKhanhstreetfoods"
             x:Class="VinhKhanhstreetfoods.Views.Components.NowPlayingBar"
             IsVisible="{Binding IsVisible}"
             x:Name="RootView">
    
    <ContentView.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter" />
        </ResourceDictionary>
    </ContentView.Resources>

    <Border BackgroundColor="{StaticResource TextDark}"
           Padding="10,8"
           Margin="15,0,15,15"
           Style="{StaticResource MainCardStyle}"
           VerticalOptions="End"
           Shadow="{StaticResource SoftShadow}">
        
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding OpenDetailCommand}" />
        </Border.GestureRecognizers>

        <Grid RowDefinitions="Auto, Auto">
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="12" VerticalOptions="Center">
                
                <!-- Avatar -->
                <Border Grid.Column="0" 
                        WidthRequest="44" 
                        HeightRequest="44" 
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource BgPage}"
                    VerticalOptions="Center"
                    Style="{StaticResource ImageThumbnailStyle}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <Grid>
                    <!-- Fallback -->
                    <Label Text="🎵" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource TextLight}" />
                    <!-- Image -->
                    <Image Source="{Binding PoiAvatarUrl}" Aspect="AspectFill" 
                           IsVisible="{Binding PoiAvatarUrl, Converter={StaticResource InvertedBoolConverter}, ConverterParameter='StringNotEmpty'}" />
                </Grid>
            </Border>

            <!-- Info -->
            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="{Binding PoiName}" 
                       FontSize="13" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding LanguageText}" 
                       FontSize="10" 
                       TextColor="{StaticResource TextLight}" />
            </StackLayout>

            <!-- Play/Pause Button -->
            <ImageButton Grid.Column="2" 
                    Source="{Binding PlayPauseIcon}" 
                    Command="{Binding TogglePlayCommand}"
                    BackgroundColor="Transparent"
                    Padding="10"
                    HeightRequest="44"
                    WidthRequest="44" />

            <!-- Close Button -->
            <Button Grid.Column="3"
                    Text="✕"
                    Command="{Binding CloseCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextMuted}"
                    FontSize="20"
                    Padding="0"
                    VerticalOptions="Center"
                    HeightRequest="44"
                    WidthRequest="30" />
            </Grid>

            <!-- Playlist Expandable Area -->
            <StackLayout Grid.Row="1" IsVisible="{Binding IsPlaylistVisible}" Margin="0,15,0,0">
                <Label Text="{Binding NearYouText}" FontAttributes="Bold" TextColor="White" Margin="0,0,0,10"/>
                <CollectionView ItemsSource="{Binding UpcomingAudios}" HeightRequest="200">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5" ColumnDefinitions="Auto, *, Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.PlayAudioCommand}" CommandParameter="{Binding .}"/>
                                </Grid.GestureRecognizers>
                                <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" StrokeThickness="0" BackgroundColor="{StaticResource BgPage}" Style="{StaticResource ImageThumbnailStyle}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Grid>
                                        <Label Text="🎵" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource TextLight}" />
                                        <Image Source="{Binding AvatarImageUrl}" Aspect="AspectFill" />
                                    </Grid>
                                </Border>
                                <StackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                                    <Label Text="{Binding Name}" FontSize="12" FontAttributes="Bold" TextColor="White" />
                                    <Label Text="{Binding DistanceFromUser, StringFormat='{0:F0}m'}" FontSize="10" TextColor="{StaticResource TextLight}" />
                                </StackLayout>
                                <Image Grid.Column="2" Source="play_1003_svgrepo_com.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="{Binding NoLocationsText}" TextColor="{StaticResource TextLight}" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,20"/>
                    </CollectionView.EmptyView>
                </CollectionView>
            </StackLayout>
        </Grid>
    </Border>
</ContentView>