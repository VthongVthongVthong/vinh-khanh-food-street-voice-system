<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:VinhKhanhstreetfoods.Converters;assembly=VinhKhanhstreetfoods"
             xmlns:local2="clr-namespace:VinhKhanhstreetfoods.Models;assembly=VinhKhanhstreetfoods"
             xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
             x:Class="VinhKhanhstreetfoods.Views.HomePage"
             Title="Food Street"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BgPage}"
             Padding="0">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:POIDescriptionConverter x:Key="POIDescriptionConverter" />
            <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter" />
            <converters:StringNotNullOrEmptyConverter x:Key="StringNotNullOrEmptyConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- Header -->
        <Grid BackgroundColor="{StaticResource BgPage}" Padding="20,20,20,10" ColumnSpacing="12" ColumnDefinitions="*,Auto,Auto">
            <StackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                <Label x:Name="HeaderTitleLabel" Style="{StaticResource PageTitle}" TextColor="{StaticResource TextDark}" />
                <Label x:Name="HeaderLocationLabel" FontSize="13" TextColor="{StaticResource TextMuted}" />
            </StackLayout>
            <Border Grid.Column="1" Style="{StaticResource ImageThumbnailStyle}" WidthRequest="44" HeightRequest="44" BackgroundColor="White" Shadow="{StaticResource SoftShadow}" VerticalOptions="Center">
                <Image Source="bell_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border Grid.Column="2" Style="{StaticResource ImageThumbnailStyle}" WidthRequest="44" HeightRequest="44" BackgroundColor="White" Shadow="{StaticResource SoftShadow}" VerticalOptions="Center">
                <ImageButton Source="refresh_svgrepo_com.png" 
                        Padding="12"
                        BackgroundColor="Transparent"
                        Command="{Binding RefreshDataCommand}" 
                        VerticalOptions="Fill" 
                        HorizontalOptions="Fill"
                        ToolTipProperties.Text="Reload data from server" />
            </Border>
        </Grid>

        <!-- Search + QR actions -->
        <Border Grid.Row="1"
                Margin="20,10,20,16"
                Style="{StaticResource MainCardStyle}">
            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="56">
                <Image Source="search_svgrepo_com.png"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center"
                       Margin="16,0,8,0" />
                <Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       Text="{Binding SearchText}"
                       FontSize="15"
                       PlaceholderColor="{StaticResource TextLight}"
                       TextColor="{StaticResource TextDark}"
                       ClearButtonVisibility="WhileEditing"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center" />
                <ImageButton Grid.Column="2"
                        Source="qrcode_scan_svgrepo_com.png"
                        WidthRequest="40"
                        HeightRequest="40"
                        Margin="0,0,8,0"
                        BackgroundColor="{StaticResource BrandOrange}"
                        CornerRadius="20"
                        Padding="10"
                        Clicked="OnQrButtonClicked"
                        ToolTipProperties.Text="Scan QR code" />
            </Grid>
        </Border>

        <!-- POI List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshAppCommand}">
            <CollectionView ItemsSource="{Binding NearbyPOIs}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedPOI, Mode=TwoWay}"
                            SelectionChangedCommand="{Binding OpenDetailCommand}"
                            SelectionChangedCommandParameter="{Binding SelectedPOI}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local2:POI">
                        <Border Style="{StaticResource MainCardStyle}" Margin="20,0,20,0" Padding="12">
                            <Grid ColumnDefinitions="100,*" ColumnSpacing="16">
                                <Border Grid.Column="0" 
                                        Style="{StaticResource ImageThumbnailStyle}"
                                        WidthRequest="100"
                                        HeightRequest="100"
                                        BackgroundColor="{StaticResource BgPage}"
                                        IsVisible="{Binding AvatarImageUrl, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                                    <Image Source="{Binding AvatarImageUrl}" Aspect="AspectFill" />
                                </Border>
                                <BoxView Grid.Column="0" 
                                         WidthRequest="100"
                                         HeightRequest="100"
                                         Color="{StaticResource BgPage}" 
                                         CornerRadius="12"
                                         IsVisible="{Binding AvatarImageUrl, Converter={StaticResource IsNullOrEmptyConverter}}" />
                                
                                <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="6">
                                    <StackLayout Grid.Row="0" Orientation="Horizontal" Spacing="4">
                                        <Image Source="star_svgrepo_com.png" WidthRequest="12" HeightRequest="12" VerticalOptions="Center" />
                                        <Label Text="" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource TextDark}" VerticalOptions="Center" />
                                    </StackLayout>
                                    
                                    <StackLayout Grid.Row="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" Style="{StaticResource CardTitle}" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Address}" Style="{StaticResource MutedText}" FontSize="12" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding ., Converter={StaticResource POIDescriptionConverter}}" FontSize="11" TextColor="{StaticResource TextLight}" LineBreakMode="TailTruncation" MaxLines="1" />
                                    </StackLayout>
                                    
                                    <StackLayout Grid.Row="2" Orientation="Horizontal" HorizontalOptions="End">
                                        <Border Style="{StaticResource PrimaryButtonStyle}" WidthRequest="28" HeightRequest="28">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Image Source="chevron_right_svgrepo_com.png" WidthRequest="14" HeightRequest="14" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </StackLayout>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <!-- Padding at bottom for floating list visually -->
                <CollectionView.Footer>
                    <ContentView HeightRequest="20" />
                </CollectionView.Footer>
                
                <CollectionView.EmptyViewTemplate>
                    <DataTemplate>
                        <ContentView Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
                            <StackLayout Spacing="12">
                                <Label Text="😕" FontSize="40" HorizontalOptions="Center" />
                                <Label Text="No data" Style="{StaticResource CardTitle}" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                <Label Text="Pull down to refresh" Style="{StaticResource MutedText}" HorizontalOptions="Center" />
                            </StackLayout>
                        </ContentView>
                    </DataTemplate>
                </CollectionView.EmptyViewTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource BrandOrange}"
                           Scale="1.2"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <!-- Bottom Controls -->
        <ContentView Grid.Row="3" Padding="20,12,20,24" BackgroundColor="{StaticResource BgPage}">
    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
        <Border Grid.Column="0" 
                Grid.ColumnSpan="2"
                IsVisible="{Binding IsLocationServiceRunning, Converter={StaticResource InvertedBoolConverter}}"
                Style="{StaticResource PrimaryButtonStyle}"
                HeightRequest="50">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding StartLocationServiceCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                <Image Source="play_1003_svgrepo_com.png" WidthRequest="20" HeightRequest="20" />
                <Label x:Name="StartLocationButton" Text="Start Location" TextColor="White" FontSize="15" FontAttributes="Bold" />
            </HorizontalStackLayout>
        </Border>
        
        <Border Grid.Column="0" 
                Grid.ColumnSpan="2"
                IsVisible="{Binding IsLocationServiceRunning}"
                Style="{StaticResource PrimaryButtonStyle}"
                BackgroundColor="{StaticResource BrandOrangeDark}"
                HeightRequest="50">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding StopLocationServiceCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                <Image Source="pause_1006_svgrepo_com.png" WidthRequest="20" HeightRequest="20" />
                <Label x:Name="StopLocationButton" Text="Stop Location" TextColor="White" FontSize="15" FontAttributes="Bold" />
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentView>
        </Grid>

        <!-- Global Now Playing Bar overlay -->
        <components:NowPlayingBar VerticalOptions="End" Margin="0,0,0,90" />
    </Grid>
</ContentPage>