<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:VinhKhanhstreetfoods.Converters;assembly=VinhKhanhstreetfoods"
             xmlns:local2="clr-namespace:VinhKhanhstreetfoods.Models;assembly=VinhKhanhstreetfoods"
             xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
             x:Class="VinhKhanhstreetfoods.Views.HomePage"
             Title="Food Street"
             BackgroundColor="#F8F8F8"
             Padding="0">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:POIDescriptionConverter x:Key="POIDescriptionConverter" />
            <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter" />
            <converters:StringNotNullOrEmptyConverter x:Key="StringNotNullOrEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- Header -->
        <Grid BackgroundColor="White" Padding="12" ColumnSpacing="8" ColumnDefinitions="*,Auto,Auto">
            <StackLayout Grid.Column="0" Spacing="2">
                <Label x:Name="HeaderTitleLabel" FontSize="18" FontAttributes="Bold" TextColor="#1a1a1a" />
                <Label x:Name="HeaderLocationLabel" FontSize="11" TextColor="#888" />
            </StackLayout>
            <Label Grid.Column="1" Text="🔔" FontSize="24" VerticalOptions="Center" />
            <Button Grid.Column="2" 
                    Text="🔄" 
                    FontSize="20" 
                    Padding="0"
                    BackgroundColor="Transparent"
                    Command="{Binding RefreshDataCommand}" 
                    VerticalOptions="Center" 
                    HeightRequest="40" 
                    WidthRequest="40"
                    ToolTipProperties.Text="Reload data from server" />
        </Grid>

        <!-- Search + QR actions -->
        <Border Grid.Row="1"
                Margin="12"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="48">
                <Label Text="🔍"
                       FontSize="18"
                       VerticalOptions="Center"
                       Margin="14,0" />
                <Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       Text="{Binding SearchText}"
                       FontSize="14"
                       PlaceholderColor="#9E9E9E"
                       TextColor="#1a1a1a"
                       ClearButtonVisibility="WhileEditing"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="📱"
                        FontSize="18"
                        WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="#1976D2"
                        TextColor="White"
                        CornerRadius="24"
                        Padding="0"
                        Clicked="OnQrButtonClicked"
                        ToolTipProperties.Text="Scan QR code" />
            </Grid>
        </Border>

        <!-- POI List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshAppCommand}"
                     BackgroundColor="#F8F8F8">
            <CollectionView ItemsSource="{Binding NearbyPOIs}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedPOI, Mode=TwoWay}"
                            SelectionChangedCommand="{Binding OpenDetailCommand}"
                            SelectionChangedCommandParameter="{Binding SelectedPOI}"
                            BackgroundColor="#F8F8F8">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local2:POI">
                        <ContentView Padding="12,8" Margin="12,0" BackgroundColor="White">
                            <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                                <Border Grid.Column="0" 
                                        WidthRequest="80"
                                        HeightRequest="80"
                                        BackgroundColor="White"
                                        StrokeThickness="0"
                                        Padding="0"
                                             IsVisible="{Binding AvatarImageUrl, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>
                                    <Image Source="{Binding AvatarImageUrl}" 
                                           Aspect="AspectFill" />
                                </Border>
                                <BoxView Grid.Column="0" 
                                         WidthRequest="80"
                                         HeightRequest="80"
                                         Color="#E8E8E8" 
                                         CornerRadius="4"
       IsVisible="{Binding AvatarImageUrl, Converter={StaticResource IsNullOrEmptyConverter}}" />
                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                    <StackLayout Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                        <Label Text="●" FontSize="10" TextColor="#DA1C5C" />
                                        <Label Text="Open" FontSize="9" TextColor="#DA1C5C" VerticalOptions="Center" />
                                        <Label Text="●" FontSize="10" TextColor="#4CAF50" Margin="6,0,0,0" />
                                        <Label Text="Available" FontSize="9" TextColor="#4CAF50" VerticalOptions="Center" />
                                    </StackLayout>
                                    <Label Grid.Row="1" Text="{Binding Name}" FontSize="13" FontAttributes="Bold" TextColor="#1a1a1a" LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2" Text="{Binding Address}" FontSize="10" TextColor="#888" LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="3" Text="{Binding ., Converter={StaticResource POIDescriptionConverter}}" FontSize="9" TextColor="#666" LineBreakMode="WordWrap" MaxLines="2" />
                                </Grid>
                            </Grid>
                        </ContentView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyViewTemplate>
                    <DataTemplate>
                        <ContentView Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
                            <StackLayout Spacing="10">
                                <Label Text="😕" FontSize="24" HorizontalOptions="Center" />
                                <Label Text="No data" FontSize="16" FontAttributes="Bold" TextColor="#888" HorizontalOptions="Center" />
                                <Label Text="Pull down to refresh" FontSize="12" TextColor="#AAA" HorizontalOptions="Center" />
                            </StackLayout>
                        </ContentView>
                    </DataTemplate>
                </CollectionView.EmptyViewTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#1976D2"
                           Scale="1.2"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <!-- Bottom Controls -->
            <StackLayout Grid.Row="3" Spacing="8" Padding="12" BackgroundColor="White">
                <Button x:Name="StartLocationButton"
                        Command="{Binding StartLocationServiceCommand}"
                        IsVisible="{Binding IsLocationServiceRunning, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="#1976D2"
                        TextColor="White"
                        FontSize="13"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        Padding="12" />
                <Button x:Name="StopLocationButton"
                        Command="{Binding StopLocationServiceCommand}"
                        IsVisible="{Binding IsLocationServiceRunning}"
                        BackgroundColor="#FF8C00"
                        TextColor="White"
                        FontSize="13"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        Padding="12" />
            </StackLayout>
        </Grid>

        <!-- Global Now Playing Bar overlay -->
        <components:NowPlayingBar VerticalOptions="End" Margin="0,0,0,80" />
    </Grid>
</ContentPage>