<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
             x:Class="VinhKhanhstreetfoods.Views.SettingsPage"
             BackgroundColor="#F5F5F5">

    <Grid>
        <ScrollView Padding="20">
            <StackLayout Spacing="20">

                <!-- Header -->
                <Label x:Name="HeaderLabel"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#283845"
                       HorizontalOptions="Center"/>

                <!-- Language Section -->
                <Frame BackgroundColor="White"
                       BorderColor="#C9A36B"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">
                    <StackLayout Spacing="10">
                        <Label x:Name="LanguageSectionLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#283845"/>

                        <Label x:Name="UiLanguageLabel"
                               FontSize="12"
                               TextColor="#666666"/>

                        <Picker ItemsSource="{Binding LanguageOptions}"
                                SelectedItem="{Binding SelectedAppLanguage}"
                                ItemDisplayBinding="{Binding DisplayLabel}"
                                TextColor="#283845"
                                x:Name="UiLanguagePicker"/>

                        <Label x:Name="NarrationLanguageLabel"
                               FontSize="12"
                               TextColor="#666666"/>

                        <Picker ItemsSource="{Binding LanguageOptions}"
                                SelectedItem="{Binding SelectedNarrationLanguage}"
                                ItemDisplayBinding="{Binding DisplayLabel}"
                                TextColor="#283845"
                                x:Name="NarrationLanguagePicker"/>

                        <Label Text="{Binding SelectedNarrationLanguageInfo}"
                               FontSize="11"
                               TextColor="#666666"/>

                        <Button x:Name="DataFromDbButton"
                                IsEnabled="False"
                                BackgroundColor="#DDE7F0"
                                TextColor="#283845"
                                FontSize="13"
                                CornerRadius="10"
                                Padding="10"/>

                        <StackLayout Spacing="5"
                                     IsVisible="{Binding IsDownloadingLanguagePack}">
                            <Label x:Name="DownloadTitleLabel"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#283845"/>

                            <ProgressBar Progress="{Binding DownloadProgress}"
                                         ProgressColor="#C9A36B"
                                         BackgroundColor="#E8DCC8"
                                         HeightRequest="8"/>

                            <Label Text="{Binding DownloadDetails}"
                                   FontSize="11"
                                   TextColor="#666666"
                                   HorizontalOptions="Center"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <!-- Audio Settings -->
                <Frame BackgroundColor="White"
                       BorderColor="#C9A36B"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">
                    <StackLayout Spacing="15">
                        <Label x:Name="AudioTitleLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#283845"/>

                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Label x:Name="EnableAudioLabel"
                                   VerticalOptions="Center"
                                   FontSize="14"/>
                            <Switch IsToggled="{Binding EnableAudio}"
                                    HorizontalOptions="EndAndExpand"/>
                        </StackLayout>

                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Label x:Name="AutoPlayLabel"
                                   VerticalOptions="Center"
                                   FontSize="14"/>
                            <Switch IsToggled="{Binding EnableAutoNarration}"
                                    HorizontalOptions="EndAndExpand"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <!-- Cooldown Settings -->
                <Frame BackgroundColor="White"
                       BorderColor="#C9A36B"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">
                    <StackLayout Spacing="10">
                        <Label x:Name="CooldownTitleLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#283845"/>
                        <Stepper Value="{Binding CooldownMinutes}"
                                 Minimum="1"
                                 Maximum="60"
                                 Increment="1"/>
                        <Label Text="{Binding CooldownMinutes, StringFormat='Current: {0} minutes'}"
                               FontSize="12"
                               TextColor="#666666"
                               HorizontalOptions="Center"
                               x:Name="CooldownValueLabel"/>
                    </StackLayout>
                </Frame>

                <!-- Trigger Radius Settings -->
                <Frame BackgroundColor="White"
                       BorderColor="#C9A36B"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">
                    <StackLayout Spacing="10">
                        <Label x:Name="TriggerTitleLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#283845"/>
                        <Stepper Value="{Binding TriggerRadiusMeters}"
                                 Minimum="10"
                                 Maximum="100"
                                 Increment="5"/>
                        <Label Text="{Binding TriggerRadiusMeters, StringFormat='Current: {0}m'}"
                               FontSize="12"
                               TextColor="#666666"
                               HorizontalOptions="Center"
                               x:Name="TriggerValueLabel"/>
                    </StackLayout>
                </Frame>

                <!-- Status -->
                <Frame BackgroundColor="#283845"
                       CornerRadius="10"
                       Padding="10">
                    <Label Text="{Binding StatusMessage}"
                           TextColor="White"
                           FontSize="12"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"/>
                </Frame>

                <!-- Action Buttons (Only Reset) -->
                <StackLayout Spacing="10">
                    <Button x:Name="ResetButton"
                            Command="{Binding ResetSettingsCommand}"
                            BackgroundColor="#C9A36B"
                            TextColor="Black"
                            FontSize="14"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            Padding="15"/>
                </StackLayout>
            </StackLayout>
        </ScrollView>

        <!-- Language switch loading overlay -->
        <Grid IsVisible="{Binding IsApplyingLanguage}"
              BackgroundColor="#80000000"
              InputTransparent="False">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsApplyingLanguage}"
                                   IsVisible="{Binding IsApplyingLanguage}"
                                   Color="White"
                                   Scale="1.3"/>
                <Label x:Name="ApplyingLanguageLabel"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
        
        <components:NowPlayingBar VerticalOptions="End" Margin="0,0,0,20" />
    </Grid>
</ContentPage>
