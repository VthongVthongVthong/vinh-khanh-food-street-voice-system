<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
             x:Class="VinhKhanhstreetfoods.Views.SettingsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BgPage}">

    <Grid>
        <ScrollView Padding="20">
            <StackLayout Spacing="20">

                <!-- Header -->
                <Label x:Name="HeaderLabel"
                       Style="{StaticResource PageTitle}"
                       HorizontalOptions="Center"/>

                <!-- Language Section -->
                <Border Style="{StaticResource MainCardStyle}" Padding="20">
                    <StackLayout Spacing="15">
                        <Label x:Name="LanguageSectionLabel"
                               Style="{StaticResource CardTitle}"/>

                        <Label x:Name="UiLanguageLabel"
                               Style="{StaticResource MutedText}"/>

                        <Border Style="{StaticResource MainCardStyle}" BackgroundColor="{StaticResource BgPage}" Padding="10,0">
                            <Picker ItemsSource="{Binding LanguageOptions}"
                                    SelectedItem="{Binding SelectedAppLanguage}"
                                    ItemDisplayBinding="{Binding DisplayLabel}"
                                    TextColor="{StaticResource TextDark}"
                                    x:Name="UiLanguagePicker"/>
                        </Border>

                        <Label x:Name="NarrationLanguageLabel"
                               Style="{StaticResource MutedText}"/>

                        <Border Style="{StaticResource MainCardStyle}" BackgroundColor="{StaticResource BgPage}" Padding="10,0">
                            <Picker ItemsSource="{Binding LanguageOptions}"
                                    SelectedItem="{Binding SelectedNarrationLanguage}"
                                    ItemDisplayBinding="{Binding DisplayLabel}"
                                    TextColor="{StaticResource TextDark}"
                                    x:Name="NarrationLanguagePicker"/>
                        </Border>

                        <Label Text="{Binding SelectedNarrationLanguageInfo}"
                               FontSize="12"
                               TextColor="{StaticResource TextLight}"/>

                        <Button x:Name="DataFromDbButton"
                                IsEnabled="False"
                                BackgroundColor="{StaticResource BgPage}"
                                TextColor="{StaticResource TextMuted}"
                                FontSize="14"
                                CornerRadius="12"
                                Padding="12"/>

                        <StackLayout Spacing="8"
                                     IsVisible="{Binding IsDownloadingLanguagePack}">
                            <Label x:Name="DownloadTitleLabel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextDark}"/>

                            <ProgressBar Progress="{Binding DownloadProgress}"
                                         ProgressColor="{StaticResource BrandOrange}"
                                         BackgroundColor="{StaticResource BgPage}"
                                         HeightRequest="6"/>

                            <Label Text="{Binding DownloadDetails}"
                                   FontSize="12"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- Audio Settings -->
                <Border Style="{StaticResource MainCardStyle}" Padding="20">
                    <StackLayout Spacing="20">
                        <Label x:Name="AudioTitleLabel"
                               Style="{StaticResource CardTitle}"/>

                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Label x:Name="EnableAudioLabel"
                                   TextColor="{StaticResource TextDark}"
                                   VerticalOptions="Center"
                                   FontSize="15"/>
                            <Switch IsToggled="{Binding EnableAudio}"
                                    OnColor="{StaticResource BrandOrange}"
                                    HorizontalOptions="EndAndExpand"/>
                        </StackLayout>

                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Label x:Name="AutoPlayLabel"
                                   TextColor="{StaticResource TextDark}"
                                   VerticalOptions="Center"
                                   FontSize="15"/>
                            <Switch IsToggled="{Binding EnableAutoNarration}"
                                    OnColor="{StaticResource BrandOrange}"
                                    HorizontalOptions="EndAndExpand"/>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- Cooldown Settings -->
                <Border Style="{StaticResource MainCardStyle}" Padding="20">
                    <StackLayout Spacing="10">
                        <Label x:Name="CooldownTitleLabel"
                               Style="{StaticResource CardTitle}"/>
                        <Stepper Value="{Binding CooldownMinutes}"
                                 Minimum="1"
                                 Maximum="60"
                                 Increment="1"/>
                        <Label Text="{Binding CooldownMinutes, StringFormat='Current: {0} minutes'}"
                               Style="{StaticResource MutedText}"
                               HorizontalOptions="Center"
                               x:Name="CooldownValueLabel"/>
                    </StackLayout>
                </Border>

                <!-- Trigger Radius Settings -->
                <Border Style="{StaticResource MainCardStyle}" Padding="20">
                    <StackLayout Spacing="10">
                        <Label x:Name="TriggerTitleLabel"
                               Style="{StaticResource CardTitle}"/>
                        <Stepper Value="{Binding TriggerRadiusMeters}"
                                 Minimum="10"
                                 Maximum="100"
                                 Increment="5"/>
                        <Label Text="{Binding TriggerRadiusMeters, StringFormat='Current: {0}m'}"
                               Style="{StaticResource MutedText}"
                               HorizontalOptions="Center"
                               x:Name="TriggerValueLabel"/>
                    </StackLayout>
                </Border>

                <!-- Status -->
                <Border Style="{StaticResource MainCardStyle}" Padding="15" BackgroundColor="{StaticResource TextDark}">
                    <Label Text="{Binding StatusMessage}"
                           TextColor="White"
                           FontSize="13"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"/>
                </Border>

                <!-- Action Buttons (Only Reset) -->
                <StackLayout Spacing="10">
                    <Button x:Name="ResetButton"
                            Command="{Binding ResetSettingsCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource BrandOrangeDark}"
                            FontSize="15"
                            FontAttributes="Bold"
                            HeightRequest="52"/>
                </StackLayout>
            </StackLayout>
        </ScrollView>

        <!-- Language switch loading overlay -->
        <Grid IsVisible="{Binding IsApplyingLanguage}"
              BackgroundColor="#80000000"
              InputTransparent="False">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsApplyingLanguage}"
                                   IsVisible="{Binding IsApplyingLanguage}"
                                   Color="White"
                                   Scale="1.3"/>
                <Label x:Name="ApplyingLanguageLabel"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
        
        <components:NowPlayingBar VerticalOptions="End" Margin="0,0,0,20" />
    </Grid>
</ContentPage>
