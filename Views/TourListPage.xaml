<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
   xmlns:converters="clr-namespace:VinhKhanhstreetfoods.Converters;assembly=VinhKhanhstreetfoods"
   xmlns:local="clr-namespace:VinhKhanhstreetfoods.Models;assembly=VinhKhanhstreetfoods"
   xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
 x:Class="VinhKhanhstreetfoods.Views.TourListPage"
   Shell.NavBarIsVisible="False"
   BackgroundColor="{StaticResource BgPage}"
   Padding="0">

    <ContentPage.Resources>
        <ResourceDictionary>
    <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
     <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
     </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*" ColumnDefinitions="*">

  <!-- Main Content -->
    <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="0">
   
 <!-- Header -->
    <Grid Grid.Row="0" BackgroundColor="{StaticResource BgPage}" Padding="20,20,20,10" ColumnDefinitions="Auto,*" ColumnSpacing="12">
    <StackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
     <Label Text="Cac Lo Trinh" Style="{StaticResource PageTitle}" TextColor="{StaticResource TextDark}" />
<Label Text="Chon lo trinh de kham pha" FontSize="13" TextColor="{StaticResource TextMuted}" />
       </StackLayout>
      </Grid>

<!-- Content -->
        <Grid Grid.Row="1" RowDefinitions="*" BackgroundColor="{StaticResource BgPage}">

     <!-- Loading Indicator - Ensure it's on top and properly hidden -->
  <ActivityIndicator
      IsRunning="{Binding IsLoading}"
    IsVisible="{Binding IsLoading}"
      Color="{StaticResource BrandOrange}"
Scale="1.2"
    VerticalOptions="Center"
    HorizontalOptions="Center"
     Opacity="{Binding IsLoading, Converter={StaticResource BoolToOpacityConverter}}" />

  <!-- Tours List -->
     <CollectionView 
  ItemsSource="{Binding Tours}"
   SelectionMode="Single"
 SelectedItem="{Binding SelectedTour, Mode=TwoWay}"
  SelectionChangedCommand="{Binding SelectTourCommand}"
  SelectionChangedCommandParameter="{Binding SelectedTour}"
     IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">

     <CollectionView.ItemsLayout>
     <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
     </CollectionView.ItemsLayout>

      <CollectionView.ItemTemplate>
    <DataTemplate x:DataType="local:Tour">
  <Border Style="{StaticResource MainCardStyle}" Padding="16" Margin="20,0,20,0">
     <Grid ColumnDefinitions="*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">

   <!-- Tour Name -->
   <Label Grid.Row="0"
    Text="{Binding Name}"
    Style="{StaticResource CardTitle}"
       TextColor="{StaticResource TextDark}"
     LineBreakMode="WordWrap" />

      <!-- Tour Description -->
     <Label Grid.Row="1"
   Text="{Binding Description}"
    FontSize="12"
TextColor="{StaticResource TextMuted}"
   LineBreakMode="TailTruncation"
     MaxLines="2" />

     <!-- Action Text -->
    <StackLayout Grid.Row="2"
      Orientation="Horizontal"
    HorizontalOptions="End">
       <Label Text="Xem chi tiet " FontSize="11" TextColor="{StaticResource BrandOrange}" />
       <Label Text=">" FontSize="12" TextColor="{StaticResource BrandOrange}" FontAttributes="Bold" />
    </StackLayout>

         </Grid>
       </Border>
      </DataTemplate>
  </CollectionView.ItemTemplate>

   <!-- Empty State -->
  <CollectionView.EmptyViewTemplate>
    <DataTemplate>
         <ContentView Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
      <StackLayout Spacing="12" VerticalOptions="Center">
 <Label Text="No tours" FontSize="40" HorizontalOptions="Center" FontAttributes="Bold"/>
   <Label Text="Khong co lo trinh" Style="{StaticResource CardTitle}" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
         <Label Text="{Binding StatusMessage}" FontSize="12" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
        </StackLayout>
     </ContentView>
      </DataTemplate>
    </CollectionView.EmptyViewTemplate>

    <!-- Footer spacing -->
     <CollectionView.Footer>
     <ContentView HeightRequest="20" />
</CollectionView.Footer>

    </CollectionView>

        </Grid>

    </Grid>

    <!-- Now Playing Bar overlay -->
    <components:NowPlayingBar Grid.Row="0" Grid.Column="0" VerticalOptions="End" Margin="0,0,0,90" />

    </Grid>

</ContentPage>
