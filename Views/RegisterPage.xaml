<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhstreetfoods.Views.RegisterPage"
             BackgroundColor="#80000000"
             Title="Đăng Ký">
    
    <Grid>
        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 20"
                Padding="20"
                Margin="30"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="320">
            <VerticalStackLayout Spacing="15">
                <Label x:Name="TitleLabel" Text="Tạo Tài Khoản" Style="{StaticResource PageTitle}" HorizontalOptions="Center" TextColor="Black"/>

                <Entry x:Name="UsernameEntry" Placeholder="Tên đăng nhập" TextColor="Black" BackgroundColor="#EEEEEE" />
                <Entry x:Name="EmailEntry" Placeholder="Địa chỉ Email" Keyboard="Email" TextColor="Black" BackgroundColor="#EEEEEE" />
                <Entry x:Name="PhoneEntry" Placeholder="Số điện thoại" Keyboard="Telephone" TextColor="Black" BackgroundColor="#EEEEEE" />
                <Entry x:Name="PasswordEntry" Placeholder="Mật khẩu" IsPassword="True" TextColor="Black" BackgroundColor="#EEEEEE" />
                <Entry x:Name="ConfirmPasswordEntry" Placeholder="Nhập lại mật khẩu" IsPassword="True" TextColor="Black" BackgroundColor="#EEEEEE" />

                <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="{StaticResource BrandOrange}" />

                <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" HorizontalOptions="Center" HorizontalTextAlignment="Center" FontSize="12" />
                <Label x:Name="SuccessLabel" TextColor="Green" IsVisible="False" HorizontalOptions="Center" HorizontalTextAlignment="Center" FontSize="12" />

                <Button x:Name="RegisterButton" Text="Đăng ký" Clicked="OnRegisterClicked" BackgroundColor="{StaticResource BrandOrange}" TextColor="White" />
                
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label x:Name="HaveAccountLabel" Text="Đã có tài khoản?" TextColor="Gray" VerticalOptions="Center" />
                    <Label x:Name="LoginNowLabel" Text="Đăng nhập ngay" TextColor="{StaticResource BrandOrange}" FontAttributes="Bold" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <Button x:Name="CloseButton" Text="Đóng" Clicked="OnCloseClicked" BackgroundColor="Transparent" TextColor="Gray" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
