<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhstreetfoods.Views.POIDetailPage"
             Title="POI"
             BackgroundColor="#F5F5F5"
             Shell.TabBarIsVisible="False"
             Shell.TitleColor="#1a1a1a"
             Shell.ForegroundColor="#1a1a1a">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior
            x:Name="BackBehavior"
            TextOverride="Back"
            Command="{Binding GoBackCommand}" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto, *">
        <!-- Header với nút Back -->
        <Grid Grid.Row="0" Padding="15,10,15,10" ColumnDefinitions="Auto, *" BackgroundColor="White" Margin="0,0,0,5">
            <Frame BackgroundColor="#F0F0F0" CornerRadius="20" Padding="0" HasShadow="False" WidthRequest="40" HeightRequest="40" VerticalOptions="Center">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Frame.GestureRecognizers>
                <Label Text="🔙" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <Label Grid.Column="1" 
                   Text="Chi tiết nhà hàng" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="#1a1a1a" 
                   VerticalOptions="Center" 
                   Margin="15,0,0,0"/>
        </Grid>

        <ScrollView Grid.Row="1" Padding="20">
            <StackLayout Spacing="20">

                <!-- POI Header -->
            <Frame BackgroundColor="#283845"
                   CornerRadius="15"
                   Padding="20"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <Label Text="{Binding SelectedPOI.Name}"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="{Binding CurrentDescriptionText}"
                           FontSize="14"
                           TextColor="#E8E8E8"
                           LineBreakMode="WordWrap"/>
                </StackLayout>
            </Frame>

            <!-- Images Section -->
            <Frame BackgroundColor="White"
                   BorderColor="#C9A36B"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <Label x:Name="ImagesSectionLabel"
                           Text="📷 Hình Ảnh" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="#283845"/>
                    <CollectionView ItemsSource="{Binding SelectedPOI.ImageUrlList}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <StackLayout Padding="5" Spacing="5">
                                    <Border StrokeShape="RoundRectangle 10"
                                            HeightRequest="200"
                                            Padding="0">
                                        <Image Source="{Binding .}"
                                               Aspect="AspectFill"/>
                                    </Border>
                                    <Label Text="{Binding .}"
                                           FontSize="11"
                                           TextColor="#999999"
                                           LineBreakMode="TailTruncation"/>
                                </StackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Frame>

            <!-- Details Section -->
            <Frame BackgroundColor="White"
                   BorderColor="#C9A36B"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <Label x:Name="DetailsSectionLabel"
                           Text="ℹ️ Thông Tin Chi Tiết" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="#283845"/>
                    <StackLayout Padding="10" Spacing="8">
                        <Label Text="{Binding SelectedPOI.Latitude, StringFormat='Vĩ độ: {0:F5}'}"
                               FontSize="12"/>
                        <Label Text="{Binding SelectedPOI.Longitude, StringFormat='Kinh độ: {0:F5}'}"
                               FontSize="12"/>
                        <Label Text="{Binding SelectedPOI.TriggerRadius, StringFormat='Bán kính kích hoạt: {0}m'}"
                               FontSize="12"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Audio Section -->
            <Frame BackgroundColor="White"
                   BorderColor="#C9A36B"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <Label x:Name="AudioSectionLabel"
                           Text="🎙️ Âm Thanh Hướng Dẫn" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="#283845"/>

                    <Label x:Name="NarrationLanguageLabel"
                           Text="Ngôn ngữ thuyết minh"
                           FontSize="12"
                           TextColor="#666666"/>
                    <Picker ItemsSource="{Binding LanguageOptions}"
                            SelectedItem="{Binding SelectedNarrationLanguage}"
                            ItemDisplayBinding="{Binding DisplayLabel}"
                            TextColor="#283845"
                            x:Name="NarrationLanguagePicker"/>

                    <Label Text="{Binding CurrentTtsScriptText}"
                           FontSize="13"
                           TextColor="#374151"
                           LineBreakMode="WordWrap"/>
                    <Label Text="{Binding StatusMessage}"
                           FontSize="12"
                           TextColor="#666666"/>
                </StackLayout>
            </Frame>

            <!-- Action Buttons -->
            <StackLayout Spacing="10">
                <Button x:Name="PlayAudioButton"
                        Text="▶️ Phát Âm Thanh" 
                        Command="{Binding PlayAudioCommand}"
                        IsEnabled="{Binding IsPlaying, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="#283845"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Padding="15"/>
                <Button x:Name="StopAudioButton"
                        Text="⏹️ Dừng Âm Thanh" 
                        Command="{Binding StopAudioCommand}"
                        IsEnabled="{Binding IsPlaying}"
                        BackgroundColor="#C9A36B"
                        TextColor="Black"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Padding="15"/>
                <Button x:Name="OpenMapButton"
                        Text="📍 Mở Bản Đồ" 
                        Clicked="OnOpenMapPageClicked"
                        BackgroundColor="#666666"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Padding="15"/>
                <Button x:Name="ShareButton"
                        Text="📤 Chia Sẻ" 
                        Command="{Binding ShareCommand}"
                        BackgroundColor="#999999"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Padding="15"/>
            </StackLayout>
        </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
