<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
             x:Class="VinhKhanhstreetfoods.Views.POIDetailPage"
             Title="POI"
             BackgroundColor="#F5F5F5"
             Shell.TabBarIsVisible="False"
             Shell.TitleColor="#1a1a1a"
             Shell.ForegroundColor="#1a1a1a">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior
            x:Name="BackBehavior"
            TextOverride="Back"
            Command="{Binding GoBackCommand}" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto, *">
        <!-- Header với nút Back -->
        <Grid Grid.Row="0" Padding="15,10,15,10" ColumnDefinitions="Auto, *" BackgroundColor="White" Margin="0,0,0,5">
            <Frame BackgroundColor="#F0F0F0" CornerRadius="20" Padding="0" HasShadow="False" WidthRequest="40" HeightRequest="40" VerticalOptions="Center">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Frame.GestureRecognizers>
                <Image Source="back_svgrepo_com.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <Label Grid.Column="1" 
                   Text="Chi tiết nhà hàng" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="#1a1a1a" 
                   VerticalOptions="Center" 
                   Margin="15,0,0,0"/>
        </Grid>

        <ScrollView Grid.Row="1" Padding="20">
            <StackLayout Spacing="20">

                <!-- POI Header -->
            <Frame BackgroundColor="#283845"
                   CornerRadius="15"
                   Padding="20"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <Label Text="{Binding SelectedPOI.Name}"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="{Binding CurrentDescriptionText}"
                           FontSize="14"
                           TextColor="#E8E8E8"
                           LineBreakMode="WordWrap"/>
                </StackLayout>
            </Frame>

            <!-- Images Section -->
            <Frame BackgroundColor="White"
                   BorderColor="#C9A36B"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <Label x:Name="ImagesSectionLabel"
                           Text="📷 Hình Ảnh" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="#283845"/>
                    <CollectionView ItemsSource="{Binding SelectedPOI.ImageUrlList}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <StackLayout Padding="5" Spacing="5">
                                    <Border StrokeShape="RoundRectangle 10"
                                            HeightRequest="200"
                                            Padding="0">
                                        <Image Source="{Binding .}"
                                               Aspect="AspectFill"/>
                                    </Border>
                                    <Label Text="{Binding .}"
                                           FontSize="11"
                                           TextColor="#999999"
                                           LineBreakMode="TailTruncation"/>
                                </StackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Frame>

            <!-- Details Section -->
            <Frame BackgroundColor="White"
                   BorderColor="#C9A36B"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <StackLayout Orientation="Horizontal" Spacing="8">
                        <Image Source="information_alt_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label x:Name="DetailsSectionLabel"
                               Text="Thông Tin Chi Tiết" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#283845"
                               VerticalOptions="Center"/>
                    </StackLayout>
                    <StackLayout Padding="10" Spacing="8">
                        <Label Text="{Binding SelectedPOI.Latitude, StringFormat='Vĩ độ: {0:F5}'}"
                               FontSize="12"/>
                        <Label Text="{Binding SelectedPOI.Longitude, StringFormat='Kinh độ: {0:F5}'}"
                               FontSize="12"/>
                        <Label Text="{Binding SelectedPOI.TriggerRadius, StringFormat='Bán kính kích hoạt: {0}m'}"
                               FontSize="12"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Audio Section -->
            <Frame BackgroundColor="White"
                   BorderColor="#C9A36B"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <StackLayout Spacing="10">
                    <StackLayout Orientation="Horizontal" Spacing="8">
                        <Image Source="headphone_earphone_audio_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label x:Name="AudioSectionLabel"
                               Text="Âm Thanh Hướng Dẫn" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#283845"
                               VerticalOptions="Center"/>
                    </StackLayout>

                    <Label x:Name="NarrationLanguageLabel"
                           Text="Ngôn ngữ thuyết minh"
                           FontSize="12"
                           TextColor="#666666"/>
                    <Picker ItemsSource="{Binding LanguageOptions}"
                            SelectedItem="{Binding SelectedNarrationLanguage}"
                            ItemDisplayBinding="{Binding DisplayLabel}"
                            TextColor="#283845"
                            x:Name="NarrationLanguagePicker"/>

                    <Label Text="{Binding CurrentTtsScriptText}"
                           FontSize="13"
                           TextColor="#374151"
                           LineBreakMode="WordWrap"/>
                    <Label Text="{Binding StatusMessage}"
                           FontSize="12"
                           TextColor="#666666"/>
                    
                    <Label Text="Mã QR Thuyết Minh" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="#283845" 
                           Margin="0,10,0,0" />
                    <zxing:BarcodeGeneratorView
                           Format="QrCode"
                           Value="{Binding QRCodeContent}"
                           HeightRequest="200"
                           WidthRequest="200"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Frame>

            <!-- Action Buttons -->
            <StackLayout Spacing="10">
                <Border IsEnabled="{Binding IsPlaying, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="#283845"
                        StrokeThickness="0"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PlayAudioCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Image Source="play_1003_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label x:Name="PlayAudioButton" Text=" Phát Âm Thanh" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                <Border IsEnabled="{Binding IsPlaying}"
                        BackgroundColor="#C9A36B"
                        StrokeThickness="0"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding StopAudioCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Image Source="pause_1006_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label x:Name="StopAudioButton" Text=" Dừng Âm Thanh" TextColor="Black" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                <Border BackgroundColor="#666666"
                        StrokeThickness="0"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOpenMapPageTapped" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Image Source="map_pin_alt_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label x:Name="OpenMapButton" Text=" Mở Bản Đồ" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                <Button x:Name="ShareButton"
                        Text="📤 Chia Sẻ" 
                        Command="{Binding ShareCommand}"
                        BackgroundColor="#999999"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Padding="15"/>
            </StackLayout>
        </StackLayout>
        </ScrollView>

        <components:NowPlayingBar Grid.Row="1" Margin="0,0,0,20" />
    </Grid>
</ContentPage>
