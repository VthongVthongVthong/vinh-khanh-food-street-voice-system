<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             xmlns:components="clr-namespace:VinhKhanhstreetfoods.Views.Components"
             x:Class="VinhKhanhstreetfoods.Views.POIDetailPage"
             Title="POI"
             BackgroundColor="{StaticResource BgPage}"
             Shell.TabBarIsVisible="False"
             Shell.TitleColor="#1a1a1a"
             Shell.ForegroundColor="#1a1a1a">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior
            x:Name="BackBehavior"
            TextOverride="Back"
            Command="{Binding GoBackCommand}" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto, *">
        <!-- Header với nút Back -->
        <Grid Grid.Row="0" Padding="20,10,20,10" ColumnDefinitions="Auto, *" BackgroundColor="{StaticResource BgPage}" Margin="0,0,0,5">
            <Border Style="{StaticResource ImageThumbnailStyle}" WidthRequest="44" HeightRequest="44" BackgroundColor="White" Shadow="{StaticResource SoftShadow}" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Border.GestureRecognizers>
                <Image Source="back_svgrepo_com.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label Grid.Column="1" 
                   Text="Chi tiết nhà hàng" 
                   Style="{StaticResource CardTitle}"
                   VerticalOptions="Center" 
                   Margin="15,0,0,0"/>
        </Grid>

        <ScrollView Grid.Row="1" Padding="20,10,20,20">
            <StackLayout Spacing="20">

                <!-- POI Header -->
            <Border Style="{StaticResource MainCardStyle}" Padding="20" BackgroundColor="{StaticResource BrandOrange}">
                <StackLayout Spacing="5">
                    <Label Text="{Binding SelectedPOI.Name}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </StackLayout>
            </Border>

            <!-- Images Section -->
            <Border Style="{StaticResource MainCardStyle}" Padding="20">
                <StackLayout Spacing="15">
                    <Label x:Name="ImagesSectionLabel"
                           Text="📷 Hình Ảnh" 
                           Style="{StaticResource CardTitle}"/>
                    <Grid>
                        <CarouselView x:Name="ImagesCarousel"
                                      ItemsSource="{Binding SelectedPOI.ImageUrlList}"
                                      HeightRequest="250"
                                      HorizontalScrollBarVisibility="Never"
                                      IsSwipeEnabled="True"
                                      Loop="False">
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 10" Padding="0" Margin="0,0,0,10">
                                        <Image Aspect="AspectFill">
                                            <Image.Source>
                                                <UriImageSource Uri="{Binding .}" CacheValidity="14" CachingEnabled="True" />
                                            </Image.Source>
                                        </Image>
                                    </Border>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>

                        <!-- Left Button -->
                        <ImageButton Source="chevron_left_svgrepo_com.png"
                                     HorizontalOptions="Start"
                                     VerticalOptions="Center"
                                     WidthRequest="40"
                                     HeightRequest="40"
                                     BackgroundColor="#80FFFFFF"
                                     CornerRadius="20"
                                     Margin="10,0,0,0"
                                     Clicked="OnScrollLeftClicked"/>
                                     
                        <!-- Right Button -->
                        <ImageButton Source="chevron_right_svgrepo_com.png"
                                     HorizontalOptions="End"
                                     VerticalOptions="Center"
                                     WidthRequest="40"
                                     HeightRequest="40"
                                     BackgroundColor="#80FFFFFF"
                                     CornerRadius="20"
                                     Margin="0,0,10,0"
                                     Clicked="OnScrollRightClicked"/>
                    </Grid>
                    
                    <!-- MAUI IndicatorView in combination with CarouselView often crashes on teardown with IndexOutOfRange -> removed temporarily
                    <IndicatorView x:Name="ImagesIndicator"
                                   HorizontalOptions="Center"
                                   IndicatorColor="#E0E0E0"
                                   SelectedIndicatorColor="{StaticResource BrandOrange}"
                                   IndicatorSize="8" />
                    -->
                </StackLayout>
            </Border>

            <!-- Description Section -->
            <Border Style="{StaticResource MainCardStyle}" Padding="20">
                <StackLayout Spacing="10">
                    <StackLayout Orientation="Horizontal" Spacing="8">
                        <Image Source="information_alt_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label Text="Mô tả" 
                               Style="{StaticResource CardTitle}"
                               VerticalOptions="Center"/>
                    </StackLayout>
                    <Label Text="{Binding CurrentDescriptionText}"
                           FontSize="14"
                           TextColor="{StaticResource TextDark}"
                           LineBreakMode="WordWrap"/>
                </StackLayout>
            </Border>

            <!-- Audio Section -->
            <Border Style="{StaticResource MainCardStyle}" Padding="20">
                <StackLayout Spacing="10">
                    <StackLayout Orientation="Horizontal" Spacing="8">
                        <Image Source="headphone_earphone_audio_svgrepo_com.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label x:Name="AudioSectionLabel"
                               Text="Âm Thanh Hướng Dẫn" 
                               Style="{StaticResource CardTitle}"
                               VerticalOptions="Center"/>
                    </StackLayout>

                    <Label x:Name="NarrationLanguageLabel"
                           Text="Ngôn ngữ thuyết minh"
                           Style="{StaticResource MutedText}"/>
                    <Border Style="{StaticResource MainCardStyle}" BackgroundColor="{StaticResource BgPage}" Padding="10,0">
                        <Picker ItemsSource="{Binding LanguageOptions}"
                                SelectedItem="{Binding SelectedNarrationLanguage}"
                                ItemDisplayBinding="{Binding DisplayLabel}"
                                TextColor="{StaticResource TextDark}"
                                Title="Chọn ngôn ngữ"
                                x:Name="NarrationLanguagePicker"/>
                    </Border>

                    <Label Text="{Binding CurrentTtsScriptText}"
                           FontSize="14"
                           TextColor="{StaticResource TextDark}"
                           LineBreakMode="WordWrap"
                           Margin="0,10"/>
                    <Label Text="{Binding StatusMessage}"
                           FontSize="12"
                           TextColor="{StaticResource BrandOrange}"/>
                    
                    <Label Text="Mã QR Thuyết Minh" 
                           Style="{StaticResource CardTitle}"
                           Margin="0,15,0,0" />
                    <zxing:BarcodeGeneratorView
                           Format="QrCode"
                           Value="{Binding QRCodeContent}"
                           HeightRequest="200"
                           WidthRequest="200"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Border>

            <!-- Action Buttons -->
            <StackLayout Spacing="12">
                <!-- Single Play/Pause Toggle Button -->
                <Border HeightRequest="52">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="BackgroundColor" Value="{StaticResource BrandOrange}"/>
                            <Style.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource BrandOrangeDark}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleAudioCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                        <Image WidthRequest="20" HeightRequest="20">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="play_1003_svgrepo_com.png"/>
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Image" Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Source" Value="pause_1006_svgrepo_com.png"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <Label TextColor="White" FontSize="15" FontAttributes="Bold">
                            <Label.Style>
                                <Style TargetType="Label">
                                    <Setter Property="Text" Value="Phát Âm Thanh"/>
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="Dừng Âm Thanh"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Label.Style>
                        </Label>
                    </HorizontalStackLayout>
                </Border>
                
                <Button x:Name="ShareButton"
                        Text="📤 Chia Sẻ" 
                        Command="{Binding ShareCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextMuted}"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="52"/>
            </StackLayout>
        </StackLayout>
        </ScrollView>

        <components:NowPlayingBar Grid.Row="1" Margin="0,0,0,20" />
    </Grid>
</ContentPage>
