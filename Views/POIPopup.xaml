<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VinhKhanhstreetfoods.Views.POIPopup"
    BackgroundColor="Transparent">

    <Grid 
        RowDefinitions="*" 
        ColumnDefinitions="*"
        Padding="20"
        VerticalOptions="End"
    HorizontalOptions="Center">

        <!-- Popup Container with Shadow and Rounded Corners -->
        <Border 
            Grid.Row="0" 
            Grid.Column="0"
         Style="{StaticResource MainCardStyle}"
   Padding="0"
       Margin="0,0,0,20"
   WidthRequest="380"
            MaximumWidthRequest="380">

  <StackLayout Spacing="0" Padding="0">

                <!-- Banner Image -->
   <Border 
 Style="{StaticResource ImageThumbnailStyle}"
          Padding="0"
             Margin="0"
      HeightRequest="180">
      <Border.StrokeShape>
          <RoundRectangle CornerRadius="20,20,0,0" />
      </Border.StrokeShape>
    <Image 
            x:Name="BannerImage"
        Source="{Binding BannerImageUrl}"
         Aspect="AspectFill"
          IsVisible="{Binding BannerImageUrl, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
              
   <!-- Fallback placeholder if no image -->
                <BoxView 
       Color="{StaticResource BgPage}"
                IsVisible="{Binding BannerImageUrl, Converter={StaticResource IsNullOrEmptyConverter}}" />
        </Border>

        <!-- Avatar Circle (overlapping banner) -->
                <Border 
   Padding="3"
           Margin="0,-35,0,0"
    BackgroundColor="White"
    Style="{StaticResource MainCardStyle}"
      HorizontalOptions="Center"
            VerticalOptions="Start"
     WidthRequest="70"
           HeightRequest="70">
           <Border.StrokeShape>
               <RoundRectangle CornerRadius="35" />
           </Border.StrokeShape>
    <Image 
      x:Name="AvatarImage"
  Source="{Binding AvatarImageUrl}"
  Aspect="AspectFill"
   IsVisible="{Binding AvatarImageUrl, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
           
        <!-- Fallback icon if no image -->
      <Label 
        Text="??"
      FontSize="30"
             HorizontalTextAlignment="Center"
      VerticalTextAlignment="Center"
      IsVisible="{Binding AvatarImageUrl, Converter={StaticResource IsNullOrEmptyConverter}}" />
     </Border>

   <!-- Content Area -->
         <StackLayout Padding="20,15,20,20" Spacing="12">

        <!-- POI Name -->
     <Label 
            Text="{Binding CurrentPOI.Name}"
            Style="{StaticResource CardTitle}"
             LineBreakMode="TailTruncation"
    HorizontalTextAlignment="Center" />

        <!-- Description (Short) -->
         <Label 
            Text="{Binding CurrentPOI.DescriptionText}"
          Style="{StaticResource MutedText}"
 LineBreakMode="TailTruncation"
 MaxLines="3"
           HorizontalTextAlignment="Center"
      Margin="0,0,0,8" />

  <!-- Language Selector -->
      <StackLayout Spacing="6">
           <Label 
        Text="Select Language for Narration"
         Style="{StaticResource MutedText}"
         FontSize="12"
           Margin="0,8,0,0" />
   
   <Border
   Style="{StaticResource MainCardStyle}"
   BackgroundColor="{StaticResource BgPage}"
  Padding="10,0"
           Margin="0">
       <Picker 
   x:Name="LanguagePicker"
 ItemsSource="{Binding AvailableLanguages}"
        SelectedItem="{Binding SelectedLanguage}"
Title="Select Language"
      TextColor="{StaticResource TextDark}" />
         </Border>
         </StackLayout>

            <!-- Action Buttons Row -->
           <Grid 
          ColumnDefinitions="*, *" 
          ColumnSpacing="10"
        Margin="0,12,0,0">

     <!-- Close Button -->
          <Button 
     Grid.Column="0"
        Text="? Close"
         Command="{Binding CloseCommand}"
       BackgroundColor="{StaticResource BgPage}"
      TextColor="{StaticResource TextDark}"
  FontSize="14"
      FontAttributes="Bold"
        Padding="0"
        HeightRequest="48"
      CornerRadius="12" />

             <!-- Play Audio Button -->
    <StackLayout 
  Grid.Column="1"
    Spacing="0">
          <Button 
         x:Name="PlayButton"
   Text="?? Play"
Command="{Binding PlayCommand}"
         BackgroundColor="{StaticResource BrandOrange}"
  TextColor="White"
      FontSize="14"
              FontAttributes="Bold"
             Padding="0"
             HeightRequest="48"
      CornerRadius="12"
    Opacity="{Binding IsLoadingAudio, Converter={StaticResource BoolToOpacityConverter}}"
   IsEnabled="{Binding IsLoadingAudio, Converter={StaticResource InvertedBoolConverter}}" />
              
      <!-- Loading Indicator -->
         <ActivityIndicator 
                    IsRunning="{Binding IsLoadingAudio}"
           IsVisible="{Binding IsLoadingAudio}"
         Color="White"
  Margin="0,-36,0,0"
               Scale="0.8" />
       </StackLayout>
     </Grid>

        <!-- Playing Status -->
          <Label 
          Text="?? Now playing audio..."
               FontSize="12"
     TextColor="{StaticResource BrandOrange}"
              FontAttributes="Bold"
           IsVisible="{Binding IsPlayingAudio}"
      HorizontalTextAlignment="Center"
                 Margin="0,8,0,0" />

    </StackLayout>

       </StackLayout>
        </Border>
 </Grid>
</ContentView>
