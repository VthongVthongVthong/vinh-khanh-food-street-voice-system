<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
           xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhstreetfoods.Views.CameraPage"
        Title="Quét mã QR"
        Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
          BackgroundColor="#000000">

 <Grid>
        <!-- Full Screen Camera -->
  <Grid x:Name="CameraContainer"
        HorizontalOptions="Fill"
           VerticalOptions="Fill"
    BackgroundColor="#000000" />

        <!-- QR Frame: 4 Corner Lines Only -->
        <Grid HorizontalOptions="Center"
      VerticalOptions="Center"
 WidthRequest="260"
          HeightRequest="260"
   InputTransparent="True">

       <!-- Top Left Corner -->
 <BoxView Color="White" WidthRequest="40" HeightRequest="4"
  HorizontalOptions="Start" VerticalOptions="Start" />
       <BoxView Color="White" WidthRequest="4" HeightRequest="40"
      HorizontalOptions="Start" VerticalOptions="Start" />

      <!-- Top Right Corner -->
          <BoxView Color="White" WidthRequest="40" HeightRequest="4"
  HorizontalOptions="End" VerticalOptions="Start" />
   <BoxView Color="White" WidthRequest="4" HeightRequest="40"
   HorizontalOptions="End" VerticalOptions="Start" />

         <!-- Bottom Left Corner -->
   <BoxView Color="White" WidthRequest="40" HeightRequest="4"
   HorizontalOptions="Start" VerticalOptions="End" />
        <BoxView Color="White" WidthRequest="4" HeightRequest="40"
HorizontalOptions="Start" VerticalOptions="End" />

  <!-- Bottom Right Corner -->
         <BoxView Color="White" WidthRequest="40" HeightRequest="4"
      HorizontalOptions="End" VerticalOptions="End" />
 <BoxView Color="White" WidthRequest="4" HeightRequest="40"
      HorizontalOptions="End" VerticalOptions="End" />
        </Grid>

        <!-- Back Button (Floating) -->
        <Border Margin="20"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                WidthRequest="48"
                HeightRequest="48"
                BackgroundColor="#40000000"
                StrokeThickness="0"
                ZIndex="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked" />
            </Border.GestureRecognizers>
            <Image Source="back_svgrepo_com.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>
    </Grid>

</ContentPage>