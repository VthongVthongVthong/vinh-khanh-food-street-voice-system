<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VinhKhanhstreetfoods.Pages.POIPopupOverlay"
    Title="POI Popup Overlay"
    BackgroundColor="Transparent"
   NavigationPage.HasNavigationBar="False">

    <Grid 
     RowDefinitions="*"
        ColumnDefinitions="*"
    RowSpacing="0"
        ColumnSpacing="0"
  BackgroundColor="Transparent">

        <!-- Semi-transparent overlay backdrop -->
    <BoxView 
            Grid.Row="0"
      Grid.Column="0"
            Color="#000000"
 Opacity="0"
     x:Name="BackdropOverlay" />

        <!-- Popup container -->
<ContentView 
     x:Name="PopupContainer"
         Grid.Row="0"
       Grid.Column="0"
    />
    </Grid>
</ContentPage>
