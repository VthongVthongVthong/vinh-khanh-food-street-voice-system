<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  x:Class="VinhKhanhstreetfoods.Pages.HybridPOIPopupOverlay"
    BackgroundColor="Transparent"
    IsVisible="True">

    <!-- ✅ Full-screen grid overlay -->
    <Grid 
      RowDefinitions="*"
 ColumnDefinitions="*"
        RowSpacing="0"
        ColumnSpacing="0"
     BackgroundColor="Transparent"
    HorizontalOptions="Fill"
    VerticalOptions="Fill">

    <!-- Semi-transparent overlay backdrop -->
   <BoxView 
Grid.Row="0"
       Grid.Column="0"
    Color="#000000"
       Opacity="0"
       x:Name="BackdropOverlay"
    HorizontalOptions="Fill"
         VerticalOptions="Fill" />

        <!-- Popup container -->
        <ContentView 
     x:Name="PopupContainer"
       Grid.Row="0"
      Grid.Column="0"
    HorizontalOptions="Fill"
    VerticalOptions="Fill" />
    </Grid>
</ContentView>
