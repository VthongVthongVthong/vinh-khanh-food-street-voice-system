<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFoodGuide.Pages.HomePage"
             Title="Vinh Khanh Food Guide">

    <VerticalStackLayout Padding="20" Spacing="15">
        <!-- Status Section -->
        <Label Text="Tracking Status" FontSize="18" FontAttributes="Bold" />
        <Frame BorderColor="Gray" CornerRadius="10" Padding="15" HasShadow="True">
            <VerticalStackLayout Spacing="10">
                <Label Text="{Binding StatusMessage}" FontSize="14" />
                <Label Text="{Binding CurrentLocation, StringFormat='Location: {0.Latitude:F4}, {0.Longitude:F4}'}" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding NearestPoiName, StringFormat='Nearest POI: {0}'}" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding NearestPoiDistance, StringFormat='Distance: {0:F1}m'}" FontSize="12" TextColor="Gray" />
            </VerticalStackLayout>
        </Frame>

        <!-- Controls -->
        <HorizontalStackLayout Spacing="10">
            <Button x:Name="StartButton" Text="Start Tracking" Clicked="OnStartClicked" 
                    BackgroundColor="#2E7D32" TextColor="White" HorizontalOptions="FillAndExpand" />
            <Button x:Name="StopButton" Text="Stop Tracking" Clicked="OnStopClicked" 
                    BackgroundColor="#C62828" TextColor="White" HorizontalOptions="FillAndExpand" />
        </HorizontalStackLayout>

        <!-- POIs List -->
        <Label Text="Points of Interest" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0" />
        <CollectionView ItemsSource="{Binding AllPois}" SelectionMode="Single" VerticalScrollBarVisibility="Always">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15" Margin="5" BorderColor="#2E7D32" CornerRadius="10" HasShadow="True">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                            <Label Text="{Binding Category}" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding Radius, StringFormat='Radius: {0}m'}" FontSize="11" />
                            <Label Text="{Binding Priority, StringFormat='Priority: {0}'}" FontSize="11" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>

</ContentPage>
