<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFoodGuide.Pages.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="20" Spacing="15">
        <!-- General Settings -->
        <Label Text="General Settings" FontSize="18" FontAttributes="Bold" />
        <Frame BorderColor="Gray" CornerRadius="10" Padding="15" HasShadow="True">
            <VerticalStackLayout Spacing="15">
                <!-- Language -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="App Language" FontSize="14" FontAttributes="Bold" />
                    <Picker x:Name="LanguagePicker" Title="Select Language">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>English (en)</x:String>
                                <x:String>Vietnamese (vi)</x:String>
                                <x:String>French (fr)</x:String>
                                <x:String>Chinese (zh)</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>

                <!-- TTS Toggle -->
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="Enable Text-to-Speech" FontSize="14" VerticalOptions="Center" />
                    <Switch x:Name="TtsSwitch" IsToggled="True" />
                </HorizontalStackLayout>

                <!-- Update Interval -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Location Update Interval (seconds)" FontSize="14" FontAttributes="Bold" />
                    <Slider x:Name="IntervalSlider" Minimum="2" Maximum="15" Value="5" />
                    <Label x:Name="IntervalLabel" Text="5 seconds" FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- Save Button -->
        <Button x:Name="SaveButton" Text="Save Settings" Clicked="OnSaveClicked" 
                BackgroundColor="#2E7D32" TextColor="White" />

        <!-- About Section -->
        <Label Text="About" FontSize="18" FontAttributes="Bold" Margin="0,20,0,0" />
        <Frame BorderColor="Gray" CornerRadius="10" Padding="15" HasShadow="True">
            <VerticalStackLayout Spacing="5">
                <Label Text="Vinh Khanh Food Guide" FontSize="14" FontAttributes="Bold" />
                <Label Text="Version 1.0" FontSize="12" TextColor="Gray" />
                <Label Text="An audio guide for Vinh Khanh Food Street, District 4, HCMC" 
                       FontSize="11" TextColor="Gray" LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>

</ContentPage>
