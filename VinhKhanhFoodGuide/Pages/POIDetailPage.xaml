<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFoodGuide.Pages.POIDetailPage"
             Title="POI Details">

    <VerticalStackLayout Padding="20" Spacing="15">
        <!-- Image -->
        <Frame BorderColor="Gray" CornerRadius="10" Padding="0" HasShadow="True" HeightRequest="250">
            <Image x:Name="PoiImage" Aspect="AspectFill" Source="placeholder.png" />
        </Frame>

        <!-- POI Details -->
        <Label x:Name="PoiNameLabel" Text="POI Name" FontSize="24" FontAttributes="Bold" />
        <Label x:Name="PoiCategoryLabel" Text="Category" FontSize="14" TextColor="Gray" />

        <!-- Language Selection -->
        <Label Text="Select Language" FontSize="14" FontAttributes="Bold" />
        <Picker x:Name="LanguagePicker" Title="Choose Language">
            <Picker.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>English</x:String>
                    <x:String>Vietnamese</x:String>
                </x:Array>
            </Picker.ItemsSource>
        </Picker>

        <!-- Content/Description -->
        <Label Text="Description" FontSize="14" FontAttributes="Bold" Margin="0,10,0,0" />
        <Label x:Name="ContentLabel" Text="Description will appear here..." FontSize="12" LineBreakMode="WordWrap" />

        <!-- Audio Controls -->
        <HorizontalStackLayout Spacing="10">
            <Button x:Name="PlayButton" Text="▶ Play" Clicked="OnPlayClicked" 
                    BackgroundColor="#2E7D32" TextColor="White" />
            <Button x:Name="StopButton" Text="⏹ Stop" Clicked="OnStopClicked" 
                    BackgroundColor="#C62828" TextColor="White" />
        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentPage>
