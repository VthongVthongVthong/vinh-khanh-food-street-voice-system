<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhstreetfoods.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanhstreetfoods.Views">

    <TabBar>
        <ShellContent 
            Title="Trang Chủ" 
            ContentTemplate="{DataTemplate local:HomePage}" 
            Route="HomePage" />
        <ShellContent 
            Title="Bản Đồ" 
            ContentTemplate="{DataTemplate local:MapPage}" 
            Route="MapPage" />
        <ShellContent 
            Title="Chi Tiết" 
            ContentTemplate="{DataTemplate local:POIDetailPage}" 
            Route="POIDetailPage" />
        <ShellContent 
            Title="Cài Đặt" 
            ContentTemplate="{DataTemplate local:SettingsPage}" 
            Route="SettingsPage" />
    </TabBar>
</Shell>
