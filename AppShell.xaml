<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhstreetfoods.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanhstreetfoods.Views"
    FlyoutBehavior="Disabled"
    BackgroundColor="White">

    <TabBar>
        <ShellContent Title="Home" Icon="home.png" Route="home" ContentTemplate="{DataTemplate local:HomePage}"/>
        <ShellContent Title="Tours" Icon="route.png" Route="tour" ContentTemplate="{DataTemplate local:TourListPage}"/>
     <ShellContent Title="Map" Icon="map.png" Route="map" ContentTemplate="{DataTemplate local:MapPage}"/>
 <ShellContent Title="Settings" Icon="settings.png" Route="settings" ContentTemplate="{DataTemplate local:SettingsPage}"/>
    </TabBar>

    <ShellContent Route="tourdetail" ContentTemplate="{DataTemplate local:TourDetailPage}" />
    <ShellContent Route="detail" ContentTemplate="{DataTemplate local:POIDetailPage}" />
    <ShellContent Route="camera" ContentTemplate="{DataTemplate local:CameraPage}" />
</Shell>
